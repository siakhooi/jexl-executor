#!/bin/sh
set -e

RELEASE_VERSION=1.5.0
RELEASE_TITLE="$RELEASE_VERSION"
RELEASE_NOTE='- fix sonar issues
- code refactor and cleanup
- unit test coverage
- enhancement: add --jexl-debug option to enable JEXL script engine debug
