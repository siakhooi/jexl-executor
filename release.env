#!/bin/sh
set -e

RELEASE_VERSION=1.6.2
RELEASE_TITLE="$RELEASE_VERSION"
RELEASE_NOTE='- Windows: portable zip plus jpackage EXE and MSI installers on GitHub Releases'
RELEASE_VENDOR='Siak Hooi'
RELEASE_PACKAGE_NAME=jexl-executor
# Stable reverse-DNS id for jpackage macOS PKG/DMG; keep in sync with $ReleaseMacPackageIdentifier in release.ps1
RELEASE_MAC_PACKAGE_IDENTIFIER=io.github.siakhooi.jexl-executor
export RELEASE_VERSION RELEASE_TITLE RELEASE_NOTE RELEASE_VENDOR RELEASE_PACKAGE_NAME RELEASE_MAC_PACKAGE_IDENTIFIER
